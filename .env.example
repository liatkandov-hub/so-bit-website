# PostgreSQL connection string (Supabase, etc). Used as the fallback store for
# leads when the BAPI is unreachable. Leave unset locally to develop without a DB.
DATABASE_URL="postgresql://user:password@host:5432/sobit?schema=public"

# BAPI lead intake endpoint. Defaults to the local mock route when unset.
BAPI_URL="http://localhost:3000/api/mock-bapi"

# Set to "true" to force the local mock BAPI to simulate downtime,
# exercising the DB-fallback + retry path.
BAPI_MOCK_FAIL="false"
