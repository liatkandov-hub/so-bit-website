generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  SYNCED
  PENDING
  FAILED
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  phone       String
  email       String?
  product     String
  notes       String?
  source      String?
  status      LeadStatus @default(PENDING)
  bapiAttempts Int       @default(0)
  bapiSyncedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([product])
}
